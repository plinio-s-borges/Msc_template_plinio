  institution = {Potsdam Institute for Climate Impact Research (PIK)},
  doi = {10.48485/PIK.2025.017},
  urldate = {2025-10-29},
  abstract = {The Planetary Health Check (PHC) Report provides an assessment of the state of our planet. It is based on the Planetary Boundaries (PBs) -- the nine processes that are known to regulate the stability, resilience (ability to absorb disruptions) and life-support functions of our planet. Each of these processes, such as Climate Change or Ocean Acidification, is currently quantified by one or two Control variables. The 2025 PHC report concludes that seven out of nine Planetary Boundaries have been breached, with all of those seven showing trends of increasing pressure -- suggesting further deterioration and destabilization of planetary health in the near future.},
