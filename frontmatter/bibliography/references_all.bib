@article{andela_humandriven_2017,
  title = {A Human-Driven Decline in Global Burned Area},
  author = {Andela, N. and Morton, D. C. and Giglio, L. and Chen, Y. and family=Werf, given=G. R., prefix=van der, useprefix=true and Kasibhatla, P. S. and DeFries, R. S. and Collatz, G. J. and Hantson, S. and Kloster, S. and Bachelet, D. and Forrest, M. and Lasslop, G. and Li, F. and Mangeon, S. and Melton, J. R. and Yue, C. and Randerson, J. T.},
