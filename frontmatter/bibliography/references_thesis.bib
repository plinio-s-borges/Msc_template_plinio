@techreport{sakschewski_planetary_2025,
  title = {Planetary {{Health Check}} 2025: {{A Scientific Assessment}} of the {{State}} of the {{Planet}}},
  shorttitle = {Planetary {{Health Check}} 2025},
  author = {Sakschewski, Boris and Caesar, Levke and Andersen, Lauren and Bechthold, Max and Bergfeld, Lotta and Beusen, Arthur and Billing, Maik and Bodirsky, Benjamin Leon and Botsyun, Svetlana and Dennis, Donovan P. and Donges, Jonathan and Dou, Xinyu and Eriksson, Axel and Fetzer, Ingo and Gerten, Dieter and H{\"a}yh{\"a}, Tiina and Hebden, Sophie and Heckmann, Tim and Heilemann, Adrian and Huiskamp, Willem and Jahnke, Annika and Kaiser, Jonas and Kitzmann, Niklas H. and Kr{\"o}nke, Jonathan and K{\"u}hnel, Dana and Laureanti, Nicole C. and Li, Chaohui and Liu, Zhu and Loriani, Sina and Ludescher, Josef and Mathesius, Sabine and Norstr{\"o}m, Albert and Otto, Friederike and Paolucci, Anja and Pokhotelov, Dimitry and Rafiezadeh Shahi, Kasra and Raju, Emmanuel and Rostami, Masoud and Schaphoff, Sibyll and Schmidt, Christian and Steinert, Norman J. and Stenzel, Fabian and Virkki, Vili and {Wendt-Potthoff}, Katrin and Wunderling, Nico and Rockstr{\"o}m, Johan and Kitzmann, Niklas Henrik and Caesar, Levke and Sakschewski, Boris and Rockstr{\"o}m, Johan},
  year = 2025,
  month = sep,
  journal = {Planetary Boundaries Science (PBScience)},
  pages = {144 pages, 22 MB},
  institution = {Potsdam Institute for Climate Impact Research (PIK)},
  doi = {10.48485/PIK.2025.017},
  url = {https://publications.pik-potsdam.de/pubman/item/item_32589},
  urldate = {2025-10-29},
  abstract = {The Planetary Health Check (PHC) Report provides an assessment of the state of our planet. It is based on the Planetary Boundaries (PBs) -- the nine processes that are known to regulate the stability, resilience (ability to absorb disruptions) and life-support functions of our planet. Each of these processes, such as Climate Change or Ocean Acidification, is currently quantified by one or two Control variables. The 2025 PHC report concludes that seven out of nine Planetary Boundaries have been breached, with all of those seven showing trends of increasing pressure -- suggesting further deterioration and destabilization of planetary health in the near future.},
  copyright = {Creative Commons Attribution 4.0 International},
  langid = {english},
  file = {C:\Users\AIfogo\Zotero\storage\RBZYIEK3\Sakschewski et al. - 2025 - Planetary Health Check 2025 A Scientific Assessment of the State of the Planet.pdf}
}

