{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build LaTeX (LuaLaTeX + Biber)",
            "type": "shell",
            "command": "lualatex",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "-shell-escape",
                "${workspaceFolder}/main.tex"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Run Biber",
            "type": "shell",
            "command": "biber",
            "args": [
                "main"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "Full Build (LuaLaTeX + Biber + LuaLaTeX)",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-NoProfile",
                "-Command",
                "$ErrorActionPreference=\"Continue\"; & lualatex -synctex=1 -interaction=nonstopmode -file-line-error -shell-escape main.tex; & biber main; & lualatex -synctex=1 -interaction=nonstopmode -file-line-error -shell-escape main.tex; & lualatex -synctex=1 -interaction=nonstopmode -file-line-error -shell-escape main.tex; exit 0"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "Clean LaTeX Auxiliary Files",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "Remove-Item -Path '*.aux', '*.bbl', '*.blg', '*.idx', '*.ind', '*.lof', '*.lot', '*.out', '*.toc', '*.acn', '*.acr', '*.alg', '*.glg', '*.glo', '*.gls', '*.fls', '*.fdb_latexmk', '*.synctex.gz', '*.auxlock', '*.figlist', '*.makefile', '*.run.xml', '*.bcf' -ErrorAction SilentlyContinue"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "Fast Compile (Custom Script)",
            "type": "shell",
            "command": "${workspaceFolder}/fast_compile.bat",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "options": {
                "cwd": "${workspaceFolder}"
            }
        }
    ]
}